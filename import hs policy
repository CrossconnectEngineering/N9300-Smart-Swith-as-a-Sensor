#!/usr/bin/env python3
"""
Create Hypershield network objects and stage network policies into an OPEN
policy group from CSV files.

The write path uses HS-MP-API endpoints:
  POST /v1/network-object
  POST /v1/policy-group
  POST /v1/policy-group/{id}/add-network-policy
  GET  /v1/policy-group/{id}/check-validity

The optional SCC/CDO path is used for tenant/token preflight and for hydrating
network object addresses from existing SCC target objects.
"""

from __future__ import annotations

import argparse
import csv
import ipaddress
import json
import os
import re
import ssl
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
import uuid
from dataclasses import asdict, dataclass, field
from typing import Any, Optional


DRY_RUN_NAMESPACE = uuid.UUID("372be5c1-e518-4f4f-95f3-dc4b61d1b611")
VALID_OBJECT_TYPES = {"NETWORK", "TETRAGON"}
VALID_EFFECTS = {"permit", "forbid"}
VALID_EFFECT_AND = {"warn", "alert", "inspect", "nolog"}
VALID_PROTOCOLS = {"tcp", "udp", "icmp"}
PORT_RE = re.compile(r"^[0-9,\-\s]+$")


class ImportErrorWithContext(Exception):
    pass


class HttpApiError(Exception):
    def __init__(self, method: str, url: str, status: int, body: str):
        self.method = method
        self.url = url
        self.status = status
        self.body = body
        super().__init__(f"{method} {url} failed with HTTP {status}: {body}")


@dataclass
class NetworkObjectSpec:
    row_num: int
    object_key: str
    name: str
    description: str = ""
    object_type: str = "NETWORK"
    addresses: list[str] = field(default_factory=list)
    vrf: Optional[str] = None
    vlan: list[int] = field(default_factory=list)
    pod_labels: list[str] = field(default_factory=list)
    kube_namespaces: list[str] = field(default_factory=list)
    existing_id: str = ""
    scc_object_name: str = ""

    def payload(self) -> dict[str, Any]:
        return {
            "name": self.name,
            "description": self.description,
            "vlan": self.vlan or None,
            "vrf": self.vrf or None,
            "addresses": self.addresses or None,
            "podLabels": self.pod_labels or None,
            "kubeNamespaces": self.kube_namespaces or None,
            "objectType": self.object_type,
        }


@dataclass
class PolicyRule:
    protocol: str
    source_port: str = ""
    destination_port: str = ""

    def payload(self) -> dict[str, Any]:
        item: dict[str, Any] = {"protocol": self.protocol}
        if self.source_port:
            item["sourcePort"] = self.source_port
        if self.destination_port:
            item["destinationPort"] = self.destination_port
        return item


@dataclass
class PolicySpec:
    row_nums: list[int]
    policy_key: str
    name: str
    description: str
    effect: str
    effect_and: str
    source_ref: str
    destination_ref: str
    rules: list[PolicyRule] = field(default_factory=list)
    policy_id: str = ""

    def payload(self, source_id: str, destination_id: str) -> dict[str, Any]:
        body: dict[str, Any] = {
            "name": self.name,
            "description": self.description,
            "effect": self.effect,
            "effectAnd": self.effect_and,
            "rules": [rule.payload() for rule in self.rules],
            "sourceId": source_id,
            "destinationId": destination_id,
        }
        if self.policy_id:
            body["id"] = self.policy_id
        return body


@dataclass
class PolicyGroupSpec:
    name: str
    description: str = ""


class JsonApiClient:
    def __init__(
        self,
        base_url: str,
        token: str,
        timeout: float = 30.0,
        insecure: bool = False,
    ):
        self.base_url = base_url.rstrip("/")
        self.token = token
        self.timeout = timeout
        self.context = ssl._create_unverified_context() if insecure else None

    def get(self, path: str, query: Optional[dict[str, Any]] = None) -> Any:
        return self.request("GET", path, query=query)

    def post(self, path: str, body: dict[str, Any]) -> Any:
        return self.request("POST", path, body=body)

    def request(
        self,
        method: str,
        path: str,
        *,
        query: Optional[dict[str, Any]] = None,
        body: Optional[dict[str, Any]] = None,
    ) -> Any:
        url = self._url(path, query)
        data = None
        headers = {
            "Accept": "application/json",
            "Authorization": f"Bearer {self.token}",
        }
        if body is not None:
            data = json.dumps(body).encode("utf-8")
            headers["Content-Type"] = "application/json"

        req = urllib.request.Request(
            url,
            data=data,
            headers=headers,
            method=method,
        )
        try:
            with urllib.request.urlopen(
                req,
                timeout=self.timeout,
                context=self.context,
            ) as resp:
                raw = resp.read().decode("utf-8")
                return decode_response(raw, resp.headers.get("Content-Type"))
        except urllib.error.HTTPError as exc:
            raw = exc.read().decode("utf-8", errors="replace")
            raise HttpApiError(method, url, exc.code, raw) from exc

    def _url(self, path: str, query: Optional[dict[str, Any]]) -> str:
        if not path.startswith("/"):
            path = f"/{path}"
        url = f"{self.base_url}{path}"
        if query:
            clean_query = {
                key: str(value)
                for key, value in query.items()
                if value is not None and value != ""
            }
            if clean_query:
                url = f"{url}?{urllib.parse.urlencode(clean_query)}"
        return url


class HsMpApi:
    def __init__(self, client: JsonApiClient):
        self.client = client

    def find_network_object_by_name(self, name: str) -> Optional[dict[str, Any]]:
        offset = 0
        limit = 100
        while True:
            page = self.client.get(
                "/v1/network-object",
                {
                    "limit": limit,
                    "offset": offset,
                    "search": name,
                    "searchBy": "name",
                },
            )
            items = page.get("data", []) if isinstance(page, dict) else []
            for item in items:
                if item.get("name") == name:
                    return item
            total = int(page.get("total", len(items))) if isinstance(page, dict) else 0
            if not items or offset + len(items) >= total:
                return None
            offset += len(items)

    def create_network_object(self, spec: NetworkObjectSpec) -> dict[str, Any]:
        return self.client.post("/v1/network-object", spec.payload())

    def get_in_progress_policy_group(self) -> Optional[dict[str, Any]]:
        result = self.client.get("/v1/policy-group/in-progress")
        return result if isinstance(result, dict) and result.get("id") else None

    def create_policy_group(self, spec: PolicyGroupSpec) -> dict[str, Any]:
        return self.client.post(
            "/v1/policy-group",
            {"name": spec.name, "description": spec.description},
        )

    def add_network_policy(
        self,
        policy_group_id: str,
        policy: PolicySpec,
        source_id: str,
        destination_id: str,
    ) -> dict[str, Any]:
        return self.client.post(
            f"/v1/policy-group/{policy_group_id}/add-network-policy",
            policy.payload(source_id, destination_id),
        )

    def check_policy_group_validity(self, policy_group_id: str) -> dict[str, Any]:
        return self.client.get(f"/v1/policy-group/{policy_group_id}/check-validity")


class SccApi:
    def __init__(self, client: JsonApiClient):
        self.client = client

    def get_user_settings(self) -> dict[str, Any]:
        result = self.client.get("/aegis/rest/v1/user/settings")
        if not isinstance(result, dict):
            raise ImportErrorWithContext("SCC user settings returned a non-object response.")
        return result

    def list_target_objects(self, limit: int = 100, max_pages: int = 100) -> list[dict[str, Any]]:
        query = "(cdoInternal:false AND (objectType:NETWORK_OBJECT OR objectType:SERVICE_OBJECT))"
        objects: list[dict[str, Any]] = []
        for page_num in range(max_pages):
            page = self.client.get(
                "/aegis/rest/v1/services/targets/objects",
                {
                    "q": query,
                    "limit": limit,
                    "offset": page_num * limit,
                    "sort": "name:asc",
                },
            )
            if not isinstance(page, list):
                raise ImportErrorWithContext(
                    "SCC target objects response was not a list. "
                    "Check the SCC base URL and token scope."
                )
            if not page:
                break
            objects.extend(page)
            if len(page) < limit:
                break
        return objects


def decode_response(raw: str, content_type: Optional[str]) -> Any:
    if not raw:
        return None
    if content_type and "application/json" not in content_type.lower():
        return raw
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return raw


def read_csv_rows(path: str) -> list[dict[str, str]]:
    with open(path, newline="", encoding="utf-8-sig") as handle:
        reader = csv.DictReader(handle)
        if not reader.fieldnames:
            raise ImportErrorWithContext(f"{path} has no CSV headers.")
        rows: list[dict[str, str]] = []
        for idx, row in enumerate(reader, start=2):
            normalized: dict[str, str] = {"__row_num": str(idx)}
            for key, value in row.items():
                if key is None:
                    continue
                normalized[normalize_header(key)] = (value or "").strip()
            if any(value for key, value in normalized.items() if key != "__row_num"):
                rows.append(normalized)
        return rows


def normalize_header(value: str) -> str:
    return value.strip().lower().replace("-", "_").replace(" ", "_")


def field_value(row: dict[str, str], *names: str, default: str = "") -> str:
    for name in names:
        value = row.get(normalize_header(name), "")
        if value != "":
            return value
    return default


def split_list(value: str) -> list[str]:
    if not value:
        return []
    return [item.strip() for item in re.split(r"[;|]", value) if item.strip()]


def parse_vlan(value: str, row_num: int) -> list[int]:
    vlans: list[int] = []
    for raw in split_list(value):
        try:
            vlan = int(raw, 10)
        except ValueError as exc:
            raise ImportErrorWithContext(f"Row {row_num}: VLAN '{raw}' is not an integer.") from exc
        if vlan < 1 or vlan > 4094:
            raise ImportErrorWithContext(f"Row {row_num}: VLAN '{vlan}' must be 1-4094.")
        vlans.append(vlan)
    return vlans


def validate_ip_or_cidr(value: str, row_num: int) -> None:
    try:
        if "/" in value:
            ipaddress.ip_network(value, strict=False)
        else:
            ipaddress.ip_address(value)
    except ValueError as exc:
        raise ImportErrorWithContext(f"Row {row_num}: invalid IP/CIDR '{value}'.") from exc


def validate_label_list(values: list[str], row_num: int, field_name: str) -> None:
    for value in values:
        if " " in value or "=" not in value:
            raise ImportErrorWithContext(
                f"Row {row_num}: {field_name} values must use key=value format; got '{value}'."
            )


def parse_network_objects(path: str) -> list[NetworkObjectSpec]:
    specs: list[NetworkObjectSpec] = []
    seen_keys: set[str] = set()
    seen_names: set[str] = set()

    for row in read_csv_rows(path):
        row_num = int(row["__row_num"])
        name = field_value(row, "name")
        if not name:
            raise ImportErrorWithContext(f"Row {row_num}: network object name is required.")
        object_key = field_value(row, "object_key", "key", default=name)
        if object_key in seen_keys:
            raise ImportErrorWithContext(f"Row {row_num}: duplicate object_key '{object_key}'.")
        if name in seen_names:
            raise ImportErrorWithContext(f"Row {row_num}: duplicate object name '{name}'.")
        seen_keys.add(object_key)
        seen_names.add(name)

        object_type = field_value(row, "object_type", "objectType", default="NETWORK").upper()
        if object_type not in VALID_OBJECT_TYPES:
            raise ImportErrorWithContext(
                f"Row {row_num}: object_type must be NETWORK or TETRAGON; got '{object_type}'."
            )

        addresses = split_list(field_value(row, "addresses", "cidrs", "cidr"))
        for address in addresses:
            validate_ip_or_cidr(address, row_num)

        pod_labels = split_list(field_value(row, "pod_labels", "podLabels"))
        kube_namespaces = split_list(field_value(row, "kube_namespaces", "kubeNamespaces"))
        validate_label_list(pod_labels, row_num, "pod_labels")
        validate_label_list(kube_namespaces, row_num, "kube_namespaces")

        vrf = field_value(row, "vrf") or None
        vlan = parse_vlan(field_value(row, "vlan", "vlans"), row_num)

        if object_type == "NETWORK":
            if not addresses:
                scc_object_name = field_value(row, "scc_object_name", "cdo_object_name")
                existing_id = field_value(row, "existing_id", "id")
                if not existing_id and not scc_object_name:
                    raise ImportErrorWithContext(
                        f"Row {row_num}: NETWORK objects require addresses unless "
                        "existing_id or scc_object_name is provided."
                    )
            if vrf and vlan:
                raise ImportErrorWithContext(
                    f"Row {row_num}: NETWORK objects cannot specify both vrf and vlan."
                )
            if pod_labels or kube_namespaces:
                raise ImportErrorWithContext(
                    f"Row {row_num}: NETWORK objects cannot include Kubernetes label fields."
                )
        else:
            if addresses or vrf or vlan:
                raise ImportErrorWithContext(
                    f"Row {row_num}: TETRAGON objects cannot include addresses, vrf, or vlan."
                )

        specs.append(
            NetworkObjectSpec(
                row_num=row_num,
                object_key=object_key,
                name=name,
                description=field_value(row, "description"),
                object_type=object_type,
                addresses=addresses,
                vrf=vrf,
                vlan=vlan,
                pod_labels=pod_labels,
                kube_namespaces=kube_namespaces,
                existing_id=field_value(row, "existing_id", "id"),
                scc_object_name=field_value(row, "scc_object_name", "cdo_object_name"),
            )
        )
    return specs


def parse_policies(path: str) -> list[PolicySpec]:
    grouped: dict[str, PolicySpec] = {}

    for row in read_csv_rows(path):
        row_num = int(row["__row_num"])
        name = field_value(row, "name", "policy_name")
        if not name:
            raise ImportErrorWithContext(f"Row {row_num}: policy name is required.")
        policy_key = field_value(row, "policy_key", "key", default=name)

        effect = field_value(row, "effect", default="permit").lower()
        effect_and = field_value(row, "effect_and", "effectAnd", default="nolog").lower()
        protocol = field_value(row, "protocol").lower()
        source_ref = field_value(row, "source_object", "source", "source_ref")
        destination_ref = field_value(row, "destination_object", "destination", "destination_ref")
        source_port = field_value(row, "source_port", "sourcePort", "src_port")
        destination_port = field_value(row, "destination_port", "destinationPort", "dst_port")
        policy_id = field_value(row, "policy_id", "id")

        if effect not in VALID_EFFECTS:
            raise ImportErrorWithContext(
                f"Row {row_num}: effect must be permit or forbid; got '{effect}'."
            )
        if effect_and not in VALID_EFFECT_AND:
            raise ImportErrorWithContext(
                f"Row {row_num}: effect_and must be one of {sorted(VALID_EFFECT_AND)}; got '{effect_and}'."
            )
        if protocol not in VALID_PROTOCOLS:
            raise ImportErrorWithContext(
                f"Row {row_num}: protocol must be tcp, udp, or icmp; got '{protocol}'."
            )
        if not source_ref or not destination_ref:
            raise ImportErrorWithContext(
                f"Row {row_num}: source_object and destination_object are required."
            )
        validate_port(source_port, row_num, "source_port")
        validate_port(destination_port, row_num, "destination_port")
        if protocol == "icmp" and (source_port or destination_port):
            raise ImportErrorWithContext(f"Row {row_num}: ICMP rules must not include ports.")

        rule = PolicyRule(
            protocol=protocol,
            source_port=source_port,
            destination_port=destination_port,
        )
        description = field_value(row, "description")

        existing = grouped.get(policy_key)
        if not existing:
            grouped[policy_key] = PolicySpec(
                row_nums=[row_num],
                policy_key=policy_key,
                name=name,
                description=description,
                effect=effect,
                effect_and=effect_and,
                source_ref=source_ref,
                destination_ref=destination_ref,
                policy_id=policy_id,
                rules=[rule],
            )
            continue

        expected = {
            "name": existing.name,
            "description": existing.description,
            "effect": existing.effect,
            "effect_and": existing.effect_and,
            "source_object": existing.source_ref,
            "destination_object": existing.destination_ref,
            "policy_id": existing.policy_id,
        }
        actual = {
            "name": name,
            "description": description,
            "effect": effect,
            "effect_and": effect_and,
            "source_object": source_ref,
            "destination_object": destination_ref,
            "policy_id": policy_id,
        }
        for key, expected_value in expected.items():
            if expected_value != actual[key]:
                raise ImportErrorWithContext(
                    f"Row {row_num}: repeated policy_key '{policy_key}' has conflicting "
                    f"{key}; expected '{expected_value}', got '{actual[key]}'."
                )
        existing.row_nums.append(row_num)
        existing.rules.append(rule)

    return list(grouped.values())


def validate_port(value: str, row_num: int, field_name: str) -> None:
    if not value:
        return
    if not PORT_RE.match(value):
        raise ImportErrorWithContext(
            f"Row {row_num}: {field_name} must contain only numbers, commas, spaces, "
            f"or ranges such as 1000-2000."
        )
    for token in value.split(","):
        token = token.strip()
        if not token:
            raise ImportErrorWithContext(f"Row {row_num}: empty port token in {field_name}.")
        parts = [part.strip() for part in token.split("-")]
        if len(parts) > 2:
            raise ImportErrorWithContext(f"Row {row_num}: invalid port range '{token}'.")
        numbers = []
        for part in parts:
            try:
                port = int(part, 10)
            except ValueError as exc:
                raise ImportErrorWithContext(f"Row {row_num}: invalid port '{part}'.") from exc
            if port < 0 or port > 65535:
                raise ImportErrorWithContext(f"Row {row_num}: port '{port}' must be 0-65535.")
            numbers.append(port)
        if len(numbers) == 2 and numbers[1] <= numbers[0]:
            raise ImportErrorWithContext(
                f"Row {row_num}: port range '{token}' must have an end greater than the start."
            )


def parse_policy_group(path: Optional[str], args: argparse.Namespace) -> PolicyGroupSpec:
    if path:
        rows = read_csv_rows(path)
        if not rows:
            raise ImportErrorWithContext(f"{path} must contain one policy group row.")
        row = rows[0]
        name = field_value(row, "name", "policy_group_name")
        description = field_value(row, "description")
    else:
        name = args.policy_group_name or ""
        description = args.policy_group_description or ""

    if not name and not args.policy_group_id and not args.use_in_progress:
        timestamp = time.strftime("%Y-%m-%d %H:%M:%S")
        name = f"CSV import draft {timestamp}"

    return PolicyGroupSpec(name=name, description=description)


def hydrate_objects_from_scc(objects: list[NetworkObjectSpec], scc: SccApi) -> None:
    targets = [obj for obj in objects if obj.scc_object_name and not obj.addresses]
    if not targets:
        return

    print(f"[info] Hydrating {len(targets)} object(s) from SCC target objects...")
    cdo_objects = scc.list_target_objects()
    by_name = {str(item.get("name")): item for item in cdo_objects if item.get("name")}

    for obj in targets:
        cdo_obj = by_name.get(obj.scc_object_name)
        if not cdo_obj:
            raise ImportErrorWithContext(
                f"Row {obj.row_num}: SCC object '{obj.scc_object_name}' was not found."
            )
        if cdo_obj.get("objectType") != "NETWORK_OBJECT":
            raise ImportErrorWithContext(
                f"Row {obj.row_num}: SCC object '{obj.scc_object_name}' is "
                f"{cdo_obj.get('objectType')}, not NETWORK_OBJECT."
            )
        addresses = []
        for content in cdo_obj.get("contents", []):
            if content.get("@type") == "NetworkContent" and content.get("sourceElement"):
                addresses.append(str(content["sourceElement"]))
        if not addresses:
            raise ImportErrorWithContext(
                f"Row {obj.row_num}: SCC object '{obj.scc_object_name}' has no NetworkContent."
            )
        for address in addresses:
            validate_ip_or_cidr(address, obj.row_num)
        obj.addresses = addresses
        print(f"[info] {obj.name}: loaded {len(addresses)} address(es) from SCC.")


def validate_objects_ready(objects: list[NetworkObjectSpec]) -> None:
    for obj in objects:
        if obj.object_type != "NETWORK" or obj.existing_id or obj.addresses:
            continue
        if obj.scc_object_name:
            raise ImportErrorWithContext(
                f"Row {obj.row_num}: object '{obj.name}' depends on scc_object_name "
                f"'{obj.scc_object_name}', but no addresses are loaded. Run with "
                "--hydrate-from-scc or populate addresses explicitly."
            )
        raise ImportErrorWithContext(
            f"Row {obj.row_num}: NETWORK object '{obj.name}' has no addresses."
        )


def build_object_reference_map(
    objects: list[NetworkObjectSpec],
    created_ids: dict[str, str],
) -> dict[str, str]:
    mapping: dict[str, str] = {}
    for obj in objects:
        object_id = created_ids[obj.object_key]
        mapping[obj.object_key] = object_id
        mapping[obj.name] = object_id
        if obj.existing_id:
            mapping[obj.existing_id] = obj.existing_id
    return mapping


def dry_run_uuid(kind: str, key: str) -> str:
    return str(uuid.uuid5(DRY_RUN_NAMESPACE, f"{kind}:{key}"))


def require_id(response: dict[str, Any], label: str) -> str:
    value = response.get("id")
    if not value:
        raise ImportErrorWithContext(f"{label} response did not include an id: {response}")
    return str(value)


def run_import(args: argparse.Namespace) -> dict[str, Any]:
    objects = parse_network_objects(args.objects_csv)
    policies = parse_policies(args.policies_csv)
    policy_group = parse_policy_group(args.policy_group_csv, args)

    scc_api = build_scc_api(args)
    if scc_api and not args.skip_scc_check:
        settings = scc_api.get_user_settings()
        print(
            "[info] SCC user settings: "
            f"username={settings.get('username', '<unknown>')} "
            f"tenantUid={settings.get('tenantUid', '<unknown>')}"
        )
    elif not args.skip_scc_check:
        print("[warn] SCC preflight skipped because SCC_API_URL/CDO_URL or token was not provided.")

    if args.hydrate_from_scc:
        if not scc_api:
            raise ImportErrorWithContext(
                "--hydrate-from-scc requires --scc-api-url and --scc-token "
                "or SCC_API_URL/CDO_URL and SCC_ACCESS_TOKEN."
            )
        hydrate_objects_from_scc(objects, scc_api)
    validate_objects_ready(objects)

    offline = args.dry_run or args.offline
    hs_api = None if offline else build_hs_api(args)

    result: dict[str, Any] = {
        "dryRun": offline,
        "objects": [],
        "policyGroup": {},
        "policies": [],
        "validity": None,
    }

    object_ids: dict[str, str] = {}
    for obj in objects:
        if obj.existing_id:
            object_ids[obj.object_key] = obj.existing_id
            print(f"[info] Using existing object id for {obj.name}: {obj.existing_id}")
            result["objects"].append(
                {"key": obj.object_key, "name": obj.name, "id": obj.existing_id, "action": "use-existing-id"}
            )
            continue

        if offline:
            object_id = dry_run_uuid("network-object", obj.object_key)
            object_ids[obj.object_key] = object_id
            print(f"[dry-run] POST /v1/network-object {json.dumps(obj.payload(), sort_keys=True)}")
            result["objects"].append(
                {"key": obj.object_key, "name": obj.name, "id": object_id, "action": "would-create"}
            )
            continue

        assert hs_api is not None
        existing = hs_api.find_network_object_by_name(obj.name) if args.reuse_existing_objects else None
        if existing:
            object_id = require_id(existing, f"existing network object {obj.name}")
            object_ids[obj.object_key] = object_id
            print(f"[ok] Reusing existing network object {obj.name}: {object_id}")
            result["objects"].append(
                {"key": obj.object_key, "name": obj.name, "id": object_id, "action": "reuse-existing"}
            )
        else:
            created = hs_api.create_network_object(obj)
            object_id = require_id(created, f"created network object {obj.name}")
            object_ids[obj.object_key] = object_id
            print(f"[ok] Created network object {obj.name}: {object_id}")
            result["objects"].append(
                {"key": obj.object_key, "name": obj.name, "id": object_id, "action": "created"}
            )

    ref_map = build_object_reference_map(objects, object_ids)

    if args.policy_group_id:
        policy_group_id = args.policy_group_id
        group_action = "use-existing-id"
        print(f"[info] Using existing policy group id: {policy_group_id}")
    elif offline:
        policy_group_id = dry_run_uuid("policy-group", policy_group.name)
        group_action = "would-create"
        print(
            "[dry-run] POST /v1/policy-group "
            f"{json.dumps(asdict(policy_group), sort_keys=True)}"
        )
    else:
        assert hs_api is not None
        existing_group = hs_api.get_in_progress_policy_group() if args.use_in_progress else None
        if existing_group:
            policy_group_id = require_id(existing_group, "in-progress policy group")
            group_action = "reuse-in-progress"
            print(f"[ok] Reusing in-progress policy group {existing_group.get('name')}: {policy_group_id}")
        else:
            created_group = hs_api.create_policy_group(policy_group)
            policy_group_id = require_id(created_group, "created policy group")
            group_action = "created"
            print(f"[ok] Created policy group {policy_group.name}: {policy_group_id}")

    result["policyGroup"] = {
        "id": policy_group_id,
        "name": policy_group.name,
        "description": policy_group.description,
        "action": group_action,
    }

    for policy in policies:
        source_id = ref_map.get(policy.source_ref)
        destination_id = ref_map.get(policy.destination_ref)
        if not source_id:
            raise ImportErrorWithContext(
                f"Policy '{policy.policy_key}' source_object '{policy.source_ref}' "
                "does not match an object_key, name, or existing_id."
            )
        if not destination_id:
            raise ImportErrorWithContext(
                f"Policy '{policy.policy_key}' destination_object '{policy.destination_ref}' "
                "does not match an object_key, name, or existing_id."
            )

        payload = policy.payload(source_id, destination_id)
        if offline:
            print(
                f"[dry-run] POST /v1/policy-group/{policy_group_id}/add-network-policy "
                f"{json.dumps(payload, sort_keys=True)}"
            )
            result["policies"].append(
                {
                    "key": policy.policy_key,
                    "name": policy.name,
                    "action": "would-stage",
                    "sourceId": source_id,
                    "destinationId": destination_id,
                    "rules": len(policy.rules),
                }
            )
            continue

        assert hs_api is not None
        hs_api.add_network_policy(policy_group_id, policy, source_id, destination_id)
        print(f"[ok] Staged policy {policy.name} ({len(policy.rules)} rule(s))")
        result["policies"].append(
            {
                "key": policy.policy_key,
                "name": policy.name,
                "action": "staged",
                "sourceId": source_id,
                "destinationId": destination_id,
                "rules": len(policy.rules),
            }
        )

    if offline:
        print("[dry-run] Skipping policy-group validity check.")
    elif not args.skip_validity_check:
        assert hs_api is not None
        validity = hs_api.check_policy_group_validity(policy_group_id)
        result["validity"] = validity
        if validity.get("valid") is True:
            print("[ok] Policy group validity check passed.")
        else:
            print("[warn] Policy group validity check failed:")
            print(json.dumps(validity, indent=2, sort_keys=True))

    if args.output_json:
        with open(args.output_json, "w", encoding="utf-8") as handle:
            json.dump(result, handle, indent=2, sort_keys=True)
            handle.write("\n")
        print(f"[info] Wrote result summary: {args.output_json}")

    return result


def build_hs_api(args: argparse.Namespace) -> HsMpApi:
    if not args.hs_api_url:
        raise ImportErrorWithContext(
            "HS-MP-API URL is required. Set --hs-api-url or HS_MP_API_URL. "
            "Use the API root including /api, for example https://host.example/api."
        )
    if not args.hs_token:
        raise ImportErrorWithContext(
            "HS-MP-API bearer token is required. Set --hs-token, HS_MP_API_TOKEN, "
            "or SCC_ACCESS_TOKEN."
        )
    if "/api" not in urllib.parse.urlparse(args.hs_api_url).path:
        print(
            "[warn] --hs-api-url does not include '/api'. The generated OpenAPI "
            "server URL is /api, so most deployments need a base like https://host/api."
        )
    return HsMpApi(
        JsonApiClient(
            args.hs_api_url,
            args.hs_token,
            timeout=args.timeout,
            insecure=args.insecure,
        )
    )


def build_scc_api(args: argparse.Namespace) -> Optional[SccApi]:
    if not args.scc_api_url or not args.scc_token:
        return None
    return SccApi(
        JsonApiClient(
            args.scc_api_url,
            args.scc_token,
            timeout=args.timeout,
            insecure=args.insecure,
        )
    )


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Import CSV-defined Hypershield network objects and staged draft policies.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument("--objects-csv", required=True, help="CSV of network objects to create or reuse.")
    parser.add_argument("--policies-csv", required=True, help="CSV of policies/rules to stage.")
    parser.add_argument("--policy-group-csv", help="Optional one-row CSV containing policy group name and description.")
    parser.add_argument("--policy-group-name", help="Policy group name when --policy-group-csv is not used.")
    parser.add_argument("--policy-group-description", default="", help="Policy group description.")
    parser.add_argument("--policy-group-id", help="Use an existing OPEN policy group id instead of creating one.")
    parser.add_argument("--use-in-progress", action="store_true", help="Reuse /v1/policy-group/in-progress if present.")
    parser.add_argument(
        "--hs-api-url",
        default=os.getenv("HS_MP_API_URL", ""),
        help="HS-MP-API API root, usually ending in /api. Env: HS_MP_API_URL.",
    )
    parser.add_argument(
        "--hs-token",
        default=os.getenv("HS_MP_API_TOKEN") or os.getenv("SCC_ACCESS_TOKEN", ""),
        help="Bearer token accepted by HS-MP-API. Env: HS_MP_API_TOKEN or SCC_ACCESS_TOKEN.",
    )
    parser.add_argument(
        "--scc-api-url",
        default=os.getenv("SCC_API_URL") or os.getenv("CDO_URL", ""),
        help="Security Cloud Control/CDO base URL. Env: SCC_API_URL or CDO_URL.",
    )
    parser.add_argument(
        "--scc-token",
        default=os.getenv("SCC_ACCESS_TOKEN") or os.getenv("HS_MP_API_TOKEN", ""),
        help="Bearer token for SCC/CDO calls. Env: SCC_ACCESS_TOKEN.",
    )
    parser.add_argument("--skip-scc-check", action="store_true", help="Skip SCC /user/settings preflight.")
    parser.add_argument(
        "--hydrate-from-scc",
        action="store_true",
        help="For object rows with scc_object_name and no addresses, load addresses from SCC target objects.",
    )
    parser.add_argument(
        "--no-reuse-existing-objects",
        dest="reuse_existing_objects",
        action="store_false",
        help="Do not search by name before creating network objects.",
    )
    parser.set_defaults(reuse_existing_objects=True)
    parser.add_argument("--skip-validity-check", action="store_true", help="Do not call check-validity after staging.")
    parser.add_argument("--dry-run", action="store_true", help="Validate CSVs and print planned API writes without POSTing.")
    parser.add_argument(
        "--offline",
        action="store_true",
        help="Do not make HS-MP-API calls. Useful with --dry-run when no token is available.",
    )
    parser.add_argument("--output-json", help="Write an import summary JSON file.")
    parser.add_argument("--timeout", type=float, default=30.0, help="HTTP timeout in seconds.")
    parser.add_argument("--insecure", action="store_true", help="Disable TLS certificate verification.")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    try:
        run_import(args)
        return 0
    except (ImportErrorWithContext, HttpApiError) as exc:
        print(f"[error] {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
